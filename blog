  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --fondo: #F7F4EF;
      --musgo: #2D4A3E;
      --sage: #81AE94;
      --menta: #CFE5D5;
      --teal: #6EA89E;
      --texto: #2C2C2C;
      --texto-suave: #6B6B6B;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--fondo);
      color: var(--texto);
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      line-height: 1.6;
    }

    /* ── NAV ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--fondo);
      border-bottom: 1px solid rgba(129,174,148,0.25);
      padding: 0 5%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
    }

    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.45rem;
      font-weight: 600;
      color: var(--texto);
      text-decoration: none;
      letter-spacing: 0.01em;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-size: 0.88rem;
      font-weight: 400;
      color: var(--texto-suave);
      text-decoration: none;
      letter-spacing: 0.04em;
      transition: color 0.2s;
    }

    .nav-links a:hover,
    .nav-links a.active { color: var(--musgo); }

    .nav-cta {
      font-size: 0.85rem;
      font-weight: 500;
      background: var(--musgo);
      color: #fff;
      border: none;
      border-radius: 50px;
      padding: 0.5rem 1.25rem;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s;
    }
    .nav-cta:hover { background: #1e3329; }

    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 4px;
    }
    .hamburger span {
      display: block;
      width: 22px;
      height: 1.5px;
      background: var(--texto);
    }

    .mobile-menu {
      display: none;
      position: fixed;
      top: 64px;
      left: 0; right: 0;
      background: var(--fondo);
      border-bottom: 1px solid rgba(129,174,148,0.25);
      padding: 1.5rem 5%;
      flex-direction: column;
      gap: 1.25rem;
      z-index: 99;
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu a {
      font-size: 1rem;
      color: var(--texto-suave);
      text-decoration: none;
      font-weight: 400;
    }
    .mobile-menu a:hover { color: var(--musgo); }

    /* ── ENCABEZADO BLOG ── */
    .blog-header {
      padding: 4rem 8% 2rem;
      max-width: 1200px;
      margin: 0 auto;
      border-bottom: 1px solid rgba(129,174,148,0.2);
    }

    .blog-header .section-label {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--sage);
      margin-bottom: 0.75rem;
    }

    .blog-header h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 600;
      line-height: 1.15;
      color: var(--texto);
      margin-bottom: 0.75rem;
    }

    .blog-header p {
      font-size: 1rem;
      color: var(--texto-suave);
      max-width: 520px;
    }

    /* ── ARTÍCULO DESTACADO ── */
    .featured-wrapper {
      max-width: 1200px;
      margin: 3rem auto 0;
      padding: 0 8%;
    }

    .featured-label {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--musgo);
      margin-bottom: 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .featured-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(129,174,148,0.3);
    }

    .featured-card {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border-radius: 16px;
      overflow: hidden;
      background: var(--musgo);
      min-height: 460px;
      text-decoration: none;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .featured-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 20px 60px rgba(45,74,62,0.18);
    }

    .featured-visual {
      background: linear-gradient(135deg, #3d6655 0%, #2D4A3E 60%, #1e3329 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 3rem;
      position: relative;
      overflow: hidden;
    }

    .featured-visual::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 30% 40%, rgba(207,229,213,0.12) 0%, transparent 65%);
    }

    .featured-visual svg {
      position: relative;
      z-index: 1;
      opacity: 0.55;
    }

    .featured-content {
      padding: 3rem 3.5rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      color: #fff;
    }

    .post-categoria {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--menta);
      margin-bottom: 1rem;
    }

    .featured-content h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.6rem, 2.5vw, 2.2rem);
      font-weight: 600;
      line-height: 1.2;
      color: #fff;
      margin-bottom: 1rem;
    }

    .featured-content h2 em {
      font-style: italic;
      color: var(--menta);
    }

    .featured-content p {
      font-size: 0.95rem;
      color: rgba(255,255,255,0.72);
      line-height: 1.75;
      margin-bottom: 2rem;
    }

    .featured-meta {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.78rem;
      color: rgba(255,255,255,0.45);
    }

    .featured-meta span {
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }

    .btn-leer {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--menta);
      text-decoration: none;
      border: 1px solid rgba(207,229,213,0.35);
      border-radius: 50px;
      padding: 0.55rem 1.25rem;
      transition: all 0.2s;
      width: fit-content;
      margin-bottom: 1.5rem;
    }
    .btn-leer:hover {
      background: rgba(207,229,213,0.1);
      border-color: rgba(207,229,213,0.6);
    }

    /* ── GRILLA DE POSTS ── */
    .posts-section {
      max-width: 1200px;
      margin: 4rem auto;
      padding: 0 8%;
    }

    .posts-label {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--texto-suave);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .posts-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(129,174,148,0.25);
    }

    .posts-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .post-card {
      background: #fff;
      border-radius: 12px;
      overflow: hidden;
      text-decoration: none;
      color: var(--texto);
      border: 1px solid rgba(129,174,148,0.15);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      display: flex;
      flex-direction: column;
    }

    .post-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(45,74,62,0.1);
    }

    .post-card-visual {
      height: 140px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    .post-card-visual.verde {
      background: linear-gradient(135deg, #e8f4ec 0%, var(--menta) 100%);
    }
    .post-card-visual.teal {
      background: linear-gradient(135deg, #e0f0ef 0%, #b3d8d5 100%);
    }
    .post-card-visual.crema {
      background: linear-gradient(135deg, #f5f0e8 0%, #ede4d4 100%);
    }
    .post-card-visual.musgo-claro {
      background: linear-gradient(135deg, #d4e8de 0%, #aed0be 100%);
    }
    .post-card-visual.sage {
      background: linear-gradient(135deg, #daeee3 0%, #c0dece 100%);
    }

    .post-card-visual svg {
      opacity: 0.4;
    }

    .post-tipo {
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: rgba(255,255,255,0.75);
      color: var(--musgo);
      border-radius: 50px;
      padding: 0.2rem 0.65rem;
    }

    .post-card-body {
      padding: 1.5rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .post-card-categoria {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--sage);
      margin-bottom: 0.6rem;
    }

    .post-card h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 600;
      line-height: 1.25;
      color: var(--texto);
      margin-bottom: 0.6rem;
      flex: 1;
    }

    .post-card p {
      font-size: 0.85rem;
      color: var(--texto-suave);
      line-height: 1.65;
      margin-bottom: 1.25rem;
    }

    .post-card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 0.75rem;
      color: rgba(107,107,107,0.6);
      border-top: 1px solid rgba(129,174,148,0.12);
      padding-top: 1rem;
    }

    .post-card-footer .leer-mas {
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--musgo);
      text-decoration: none;
    }

    /* ── NEWSLETTER ── */
    .newsletter {
      background: var(--menta);
      margin: 0 8% 5rem;
      max-width: 1200px;
      margin-left: auto;
      margin-right: auto;
      border-radius: 16px;
      padding: 3rem 4rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
    }

    .newsletter-texto h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem;
      font-weight: 600;
      color: var(--musgo);
      margin-bottom: 0.4rem;
    }

    .newsletter-texto p {
      font-size: 0.9rem;
      color: #4a6e5a;
    }

    .newsletter-form {
      display: flex;
      gap: 0.75rem;
      flex-shrink: 0;
    }

    .newsletter-form input {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.88rem;
      background: #fff;
      border: 1px solid rgba(45,74,62,0.15);
      border-radius: 50px;
      padding: 0.6rem 1.25rem;
      width: 240px;
      outline: none;
      color: var(--texto);
    }

    .newsletter-form input:focus {
      border-color: var(--musgo);
    }

    .newsletter-form button {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 500;
      background: var(--musgo);
      color: #fff;
      border: none;
      border-radius: 50px;
      padding: 0.6rem 1.4rem;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.2s;
    }

    .newsletter-form button:hover { background: #1e3329; }

    /* ── FOOTER ── */
    footer {
      background: var(--musgo);
      color: rgba(255,255,255,0.75);
      padding: 3.5rem 8% 2rem;
    }

    .footer-top {
      display: flex;
      gap: 4rem;
      margin-bottom: 2.5rem;
      flex-wrap: wrap;
    }

    .footer-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem;
      font-weight: 600;
      color: #fff;
      text-decoration: none;
      display: block;
      margin-bottom: 0.75rem;
    }

    .footer-tagline {
      font-size: 0.83rem;
      color: rgba(255,255,255,0.45);
      max-width: 220px;
      line-height: 1.6;
    }

    .footer-links h4 {
      font-size: 0.78rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-bottom: 1rem;
    }

    .footer-links ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .footer-links ul a {
      font-size: 0.88rem;
      color: rgba(255,255,255,0.65);
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer-links ul a:hover { color: #fff; }

    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,0.1);
      padding-top: 1.5rem;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .footer-bottom p {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.3);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .featured-card { grid-template-columns: 1fr; }
      .featured-visual { min-height: 220px; }
      .posts-grid { grid-template-columns: repeat(2, 1fr); }
      .newsletter { flex-direction: column; text-align: center; }
      .newsletter-form { flex-direction: column; width: 100%; align-items: center; }
      .newsletter-form input { width: 100%; max-width: 320px; }
    }

    @media (max-width: 768px) {
      .nav-links, .nav-cta { display: none; }
      .hamburger { display: flex; }
      .blog-header { padding: 3rem 6% 1.5rem; }
      .featured-wrapper { padding: 0 6%; }
      .posts-section { padding: 0 6%; }
      .newsletter { margin: 0 6% 4rem; padding: 2rem; }
      .footer-top { gap: 2rem; }
    }

    @media (max-width: 580px) {
      .posts-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
